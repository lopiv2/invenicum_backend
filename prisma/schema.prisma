// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id              Int              @id @default(autoincrement())
  email           String           @unique
  password        String
  name            String?
  username        String?          @unique @db.VarChar(30)
  githubHandle    String?          @unique @map("github_handle")
  githubId        String?          @unique
  githubToken     String?          @db.Text // Guardaremos el token cifrado
  githubLinkedAt  DateTime?        @map("github_linked_at")
  avatarUrl       String?  @db.Text
  // Relaciones añadidas
  themeConfig     UserThemeConfig? // Relación 1:1 con la configuración activa
  savedThemes     CustomTheme[]    // Relación 1:N con temas guardados
  preferences     UserPreferences? // Relación 1:1 con preferencias del usuario
  integrations    UserIntegration[]
  loans           Loan[]
  containers      Container[]
  assignedItems   InventoryItem[]  @relation("UserAssignedItems")
  alerts          Alert[]
  plugins         UserPlugin[]
  createdTemplates AssetTemplate[] @relation("TemplateCreator")
  savedTemplates   UserTemplate[]
}

// ============================================
// SISTEMA DE INTEGRACIONES EXTERNAS 🔗
// ============================================
model UserIntegration {
  id        Int      @id @default(autoincrement())
  type      String   // "gemini", "telegram", "whatsapp", "ebay", "price_charting", "qr_labels"
  config    Json     // Almacenará los tokens/claves (preferiblemente cifrados)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relación con User
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type]) // Un usuario solo tiene una config por tipo de servicio
  @@map("user_integration")
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  userId    Int
  text      String   @db.Text
  isUser    Boolean
  createdAt DateTime @default(now())

  @@index([userId, createdAt]) // Para que las consultas sean rápidas
}

// Configuración del tema que el usuario tiene aplicado actualmente
model UserThemeConfig {
  id              Int      @id @default(autoincrement())
  themeColor      String   @default("#1A237E") // Hexadecimal
  themeBrightness String   @default("light")   // "light" o "dark"
  userId          Int      @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_theme_config")
}

// Biblioteca de temas creados por el usuario
model CustomTheme {
  id              String   @id @default(uuid())
  name            String
  primaryColor    String
  brightness      String   @default("light")
  userId          Int
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("custom_theme")
}

// Para no repetir la misma búsqueda (ej: "Pikachu" en "es")
model EnrichedCache {
  id          String   @id @default(uuid())
  source      String
  query       String
  locale      String
  data        Json
  createdAt   DateTime @default(now())

  @@unique([source, query, locale])
  @@map("enriched_cache")
}

//Mapeador de Apis para cache
model ApiMapper {
  id            String   @id @default(uuid())
  source        String   // 'pokemon', 'bgg', 'books'
  structureHash String   @unique 
  mappingJson   Json     // Instrucciones de mapeo
  locale        String   @default("en") 
  createdAt     DateTime @default(now())

  @@map("api_mapper")
}

// Preferencias generales del usuario (idioma, tema, etc.)
model UserPreferences {
  id              Int      @id @default(autoincrement())
  language        String   @default("en")   // Código de idioma (es, en, etc.)
  currency        String   @default("USD")
  // --- CONFIGURACIÓN DE TEMA ---
  useSystemTheme  Boolean  @default(true) @map("use_system_theme")
  
  isDarkMode      Boolean  @default(false) @map("is_dark_mode")
  aiEnabled       Boolean  @default(true) @map("ai_enabled")
  aiProvider      String   @default("gemini") @map("ai_provider") // "gemini" | "openai" | "claude"
  aiModel         String   @default("gemini-3-flash-preview") @map("ai_model")
  createdAt       DateTime @default(now())  @map("created_at")
  updatedAt       DateTime @updatedAt       @map("updated_at")
  channelOrder    String  @default("telegram,email") @map("channel_order")
  // --- CONFIGURACIÓN DE ALERTAS ---
  alertStockLow       Boolean @default(true)  @map("alert_stock_low")     // Alerta de stock bajo
  alertPreSales       Boolean @default(true)  @map("alert_pre_sales")    // Tu alerta de preventas
  alertLoanReminders  Boolean @default(true)  @map("alert_loan_reminders") // Tu recordatorio de préstamos
  
  // --- NUEVAS PROPUESTAS ---
  alertOverdueLoans   Boolean @default(true)  @map("alert_overdue_loans") // Préstamos ya vencidos
  alertMaintenance    Boolean @default(false) @map("alert_maintenance")    // Mantenimiento preventivo
  alertPriceChange    Boolean @default(false) @map("alert_price_change")   // Cambios bruscos de valor (Marketplace)
  
  userId          Int      @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

// ============================================
// SISTEMA DE PLUGINS DINÁMICOS (Server-Driven UI) 🔌
// ============================================

model Plugin {
  id           String   @id @default(uuid())
  name         String
  version      String?  @default("1.0.0")
  description  String?  @db.Text
  slot         String   
  ui           Json     
  isPublic     Boolean  @default(true) @map("is_public")
  authorAvatar String?  @db.Text

  // 🚩 CAMBIO CLAVE: Solo guardamos el String del handle de GitHub
  author       String?  @map("author_handle") 

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  installedBy  UserPlugin[]

  @@map("plugin")
}

model UserPlugin {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")

  // Relación con User
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isActive  Boolean  @default(true) @map("is_active")
  // Relación con Plugin
  pluginId  String   @map("plugin_id")
  plugin    Plugin   @relation(fields: [pluginId], references: [id], onDelete: Cascade)

  @@unique([userId, pluginId]) // Un usuario no puede instalar el mismo plugin dos veces
  @@map("user_plugin")
}

model Container {
  id            Int             @id @default(autoincrement())
  name          String
  description   String?
  isCollection  Boolean         @default(false) @map("is_collection")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  userId        Int
  user          User            @relation(fields: [userId], references: [id])
  items         InventoryItem[]
  // RELACIÓN AÑADIDA: Un contenedor puede tener muchos tipos de activo
  assetTypes    AssetType[]
  // RELACIÓN AÑADIDA: Un contenedor puede tener muchas listas de datos
  dataLists     DataList[]
  locations     Location[]
  loans         Loan[]
}

// ============================================
// NUEVO MODELO: Location (Define lugares físicos/lógicos) 📍
// ============================================
model Location {
  id            Int     @id @default(autoincrement())
  name          String
  description   String?
  
  // Jerarquía (opcional): Permite crear ubicaciones anidadas (Edificio > Piso > Sala)
  parentId      Int?    @map("parent_id")
  parent        Location?       @relation("LocationHierarchy", fields: [parentId], references: [id])
  children      Location[]      @relation("LocationHierarchy")
  
  // Relación con Container (Muchos a Uno)
  containerId   Int
  container     Container       @relation(fields: [containerId], references: [id], onDelete: Cascade)
  
  // Relación con InventoryItem (Una ubicación puede contener muchos ítems)
  inventoryItems InventoryItem[]
  
  @@map("location")
}

// NUEVO MODELO: Define la plantilla para un tipo de activo (Ej: "Ordenador")
model AssetType {
  id                Int                     @id @default(autoincrement())
  name              String
  isSerialized      Boolean                 @default(true) @map("is_serialized")
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  
  // Relación con Container (Muchos a Uno)
  containerId       Int
  container         Container               @relation(fields: [containerId], references: [id])
  
  // Relación con CustomFieldDefinition (Uno a Muchos)
  fieldDefinitions  CustomFieldDefinition[]
  inventoryItems    InventoryItem[]
  
  // Relación con las imágenes
  images           AssetTypeImage[]
  
  // 🎯 Campos para colecciones: IDs de los campos booleanos
  possessionFieldId Int?                    @map("possession_field_id")
  desiredFieldId    Int?                    @map("desired_field_id")
  
  @@map("asset_type")
}

// NUEVO MODELO: Define cada campo que tendrá un AssetType (Ej: "Serial Number", "Fecha de Compra")
model CustomFieldDefinition {
  id              Int         @id @default(autoincrement())
  name            String
  // El tipo debe ser mapeado a una cadena o un enum de la DB (TEXT, INTEGER, etc.)
  type            String      
  isRequired      Boolean     @default(false) @map("is_required")
  isSummable      Boolean     @default(false) @map("is_summable") // true si es un campo numérico que se debe sumar
  isMonetary      Boolean     @default(false) @map("is_monetary") //Solo para valor económico
  isCountable     Boolean     @default(false) @map("is_countable")

  // OPCIONAL: ID de una lista de valores predefinidos si type es 'list'
  dataListId      Int?        @map("data_list_id") 
  
  // Relación con AssetType (Muchos a Uno)
  assetTypeId     Int         @map("asset_type_id")
  assetType       AssetType   @relation(fields: [assetTypeId], references: [id], onDelete: Cascade)

  dataList        DataList?   @relation(fields: [dataListId], references: [id])

  @@map("custom_field_definition")
}


model InventoryItem {
  id                Int                     @id @default(autoincrement())
  name              String
  description       String?              @db.Text
  condition         String               @default("loose")
  barcode           String?              @unique @map("barcode")
  // 2. Identificador de Unidad (Solo para objetos seriados)
  serialNumber      String?              @unique @map("serial_number")
  // --- VALORACIÓN DE MERCADO (Campos Base) ---
  // Añadidos directamente para cálculos globales rápidos
  marketValue       Float?               @default(0) @map("market_value")
  lastPriceUpdate   DateTime?            @map("last_price_update")
  currency          String               @default("EUR") @map("currency")
  // Si AssetType.isSerialized es true, este valor siempre será 1.
  // Si es false, aquí guardamos cuántas unidades hay en esta ubicación.
  quantity          Int                     @default(1)
  // 🔑 NUEVO: Stock mínimo - para alertas de reorden
  minStock          Int                     @default(0) @map("min_stock")

  // ============================================
  // CAMPOS DE UBICACIÓN Y ASIGNACIÓN (USUARIO) 🎯
  // ============================================
  
  // RELACIÓN 1: Ubicación Física/Lógica (REQUERIDO)
  locationId        Int                     @map("location_id")
  location          Location                @relation(fields: [locationId], references: [id])

  // RELACIÓN 2: Usuario Asignado (OPCIONAL)
  assignedToUserId  Int?                    @map("assigned_to_user_id")
  assignedToUser    User?                   @relation("UserAssignedItems", fields: [assignedToUserId], references: [id])
  
  assetTypeId       Int                     @map("asset_type_id")
  assetType         AssetType               @relation(fields: [assetTypeId], references: [id])
  customFieldValues Json?                   @map("custom_field_values")
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  containerId       Int
  container         Container               @relation(fields: [containerId], references: [id])
  images            InventoryItemImage[]
  loans             Loan[]
  priceHistory      PriceHistory[]
  
  @@map("inventory_item") 
}

model PriceHistory {
  id              Int           @id @default(autoincrement())
  price           Float
  currency        String        @default("USD")
  createdAt       DateTime      @default(now())
  
  // Relación con el Item
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  inventoryItemId Int
  
  @@map("price_history") 
  @@index([inventoryItemId])
  @@index([createdAt])
}

// NUEVO MODELO: Almacena la URL o ruta de una imagen adjunta a un InventoryItem
model InventoryItemImage {
  id                Int       @id @default(autoincrement())
  url               String    // URL o ruta al archivo de la imagen
  
  // Opcional: descripción para accesibilidad o contexto
  altText           String?   @map("alt_text")
  
  // Opcional: Un número para definir el orden en el que se muestran las imágenes
  order             Int       @default(0)
  
  // Relación con InventoryItem (Muchos a Uno)
  inventoryItemId   Int       @map("inventory_item_id")
  inventoryItem     InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  createdAt         DateTime  @default(now())
  
  @@map("inventory_item_image")
}

// Modelo para las listas de datos personalizadas
model DataList {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  items       Json     // Almacenará el array de strings como JSON
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  // Relación con Container (Muchos a Uno)
  containerId Int      @map("container_id")
  container   Container @relation(fields: [containerId], references: [id], onDelete: Cascade)

  customFields CustomFieldDefinition[]

  @@map("data_list")
}

// Modelo para las imágenes de los tipos de activo
model AssetTypeImage {
  id          Int      @id @default(autoincrement())
  url         String   // URL o ruta al archivo de la imagen
  filename    String   // Nombre del archivo físico
  altText     String?  @map("alt_text")
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  // Relación con AssetType (Muchos a Uno)
  assetTypeId Int      @map("asset_type_id")
  assetType   AssetType @relation(fields: [assetTypeId], references: [id], onDelete: Cascade)

  @@map("asset_type_image")
}

// Modelo para los préstamos de artículos
model Loan {
  id                  Int       @id @default(autoincrement())
  userId              Int       @map("user_id")
  user                User      @relation(fields: [userId], references: [id])
  // Relación con Container (Muchos a Uno)
  containerId         Int       @map("container_id")
  container           Container @relation(fields: [containerId], references: [id], onDelete: Cascade)
  
  // Relación con InventoryItem (Muchos a Uno)
  inventoryItemId     Int       @map("inventory_item_id")
  inventoryItem       InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  // Permite prestar 5 cables de un stock de 100.
  quantity            Int       @default(1)
  
  itemName            String    // Nombre del artículo (copia para referencia histórica)
  borrowerName        String?
  borrowerEmail       String?
  borrowerPhone       String?
  loanDate            DateTime  @default(now()) @map("loan_date")
  expectedReturnDate  DateTime? @map("expected_return_date")
  actualReturnDate    DateTime? @map("actual_return_date")
  notes               String?
  status              String    @default("active") // 'active', 'returned', 'overdue'
  
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  
  @@map("loan")
}

model VoucherConfig {
  id           Int      @id @default(autoincrement())
  template     String   @db.Text
  logoPath     String?  // Ruta del archivo en el servidor
  updatedAt    DateTime @updatedAt

  @@map("voucher_config")
}

model Alert {
  id        Int      @id @default(autoincrement())
  title     String
  message   String   @db.Text
  type      String   @default("info") // 'info', 'warning', 'critical', 'stock_low'
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  // --- NUEVOS CAMPOS PARA NOTIFICACIONES/CALENDARIO ---
  isEvent     Boolean  @default(false) @map("is_event") // Diferencia alerta de notificación
  scheduledAt DateTime? @map("scheduled_at")             // Fecha del evento
  notifyAt    DateTime? @map("notify_at")    // Fecha exacta del aviso
  endDate     DateTime? @map("end_date")
  
  // Relación con el usuario para que cada uno vea solo sus alertas
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("alert")
}

// ============================================
// SISTEMA DE PLANTILLAS (MARKETPLACE)
// ============================================

model AssetTemplate {
  id              String   @id @default(uuid())
  name            String
  description     String   @db.Text
  category        String
  tags            Json?    // ["retro", "tecnología"]
  downloadCount   Int      @default(0)
  authorName      String   @map("author_name")
  authorAvatarUrl String?  @map("author_avatar_url") @db.Text
  
  // Estructura de campos (CustomFieldDefinition[])
  fields          Json     
  downloadUrl     String?
  version         Float    @default(1.0)
  isOfficial      Boolean  @default(false) @map("is_official")
  isPublic        Boolean  @default(true) @map("is_public")
  
  // Relación con el creador original
  creatorId       Int?     @map("creator_id")
  creator         User?    @relation("TemplateCreator", fields: [creatorId], references: [id])

  // Usuarios que han guardado/instalado esta plantilla
  users           UserTemplate[]

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("asset_template")
}

model UserTemplate {
  id              Int      @id @default(autoincrement())
  userId          Int      @map("user_id")
  templateId      String   @map("template_id")
  
  // Permite al usuario renombrar su copia local si quiere
  customName      String?  @map("custom_name") 
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  template        AssetTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([userId, templateId]) // Un usuario no guarda la misma plantilla dos veces
  @@map("user_template")
}

