# Imagen publicada (GHCR)
APP_IMAGE=ghcr.io/lopiv2/invenicum:latest

# Puerto host para exponer la app
HOST_PORT=3000

# Base de datos externa
DB_HOST=tu-host-mariadb
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=invenicum

# Seguridad JWT
JWT_SECRET=CAMBIAR_POR_UN_SECRETO_LARGO_Y_UNICO
JWT_EXPIRES_IN=24h

# Uploads
UPLOAD_FOLDER=uploads/inventory

# OAuth GitHub (si aplica)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Versionado app
MIN_SUPPORTED_APP_VERSION=0.0.0
